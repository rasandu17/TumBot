# ─────────────────────────────────────────────────────────────────────────────
# TumblerBot — .env configuration
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Tumblr ────────────────────────────────────────────────────────────────────
# 1. Create an app at https://www.tumblr.com/oauth/apps
# 2. Run `python tumblr_auth.py` to get OAUTH_TOKEN and OAUTH_SECRET
TUMBLR_CONSUMER_KEY=your_consumer_key_here
TUMBLR_CONSUMER_SECRET=your_consumer_secret_here
TUMBLR_OAUTH_TOKEN=your_oauth_token_here
TUMBLR_OAUTH_SECRET=your_oauth_secret_here

# Your Tumblr blog subdomain (e.g. "myblog" for myblog.tumblr.com)
TUMBLR_BLOG_NAME=your_blog_name_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated tags added to every post
TUMBLR_POST_TAGS=instagram,repost

# Path to a Netscape-format cookies.txt file for Instagram login
# (improves reliability for some content — leave blank if not needed)
INSTAGRAM_COOKIES_FILE=
